#include <stdio.h>
#include <stdbool.h>
bool isPowerOfTwo(int n) {
    return (n > 0) && ((n & (n - 1)) == 0);
}
int main() {
    int num = 16;
    if (isPowerOfTwo(num)) {
        printf("%d is a power of 2\n", num);
    } else {
        printf("%d is NOT a power of 2\n", num);
    }
    
    return 0;
}
