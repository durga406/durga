#include <stdio.h>
#include <stdlib.h>

int main() {
    int n = 4;
    int h[] = {10, 30, 40, 20};
    int prev2 = 0; 
    if (n == 1) {
        printf("%d\n", prev2);
        return 0;
    }
    int prev1 = abs(h[1] - h[0]);
    int current = prev1;
    for (int i = 2; i < n; i++) {
        int jump1 = prev1 + abs(h[i] - h[i - 1]);
        int jump2 = prev2 + abs(h[i] - h[i - 2]);

        current = (jump1 < jump2) ? jump1 : jump2;
        prev2 = prev1;
        prev1 = current;
    }
    printf("%d\n", current);

    return 0;
}
